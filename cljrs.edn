{:deps {tools.cli    {:git/url "https://github.com/csm/tools.cli"
                      :git/sha "260c939dba0e4d32723169ef399c4628799297a0"}
        ;; cljrs.base64 ships native Rust code, brought in as a pinned dylib.
        ;; :rust/init intentionally spells the *package* name with a hyphen
        ;; ("cljrs-base64") so the generated wrapper's Cargo.toml dependency key
        ;; matches the crate's package name — see notes/cljrs-dylib-pkgname-bug.md.
        cljrs.base64 {:git/url    "https://github.com/csm/clojurust"
                      :git/sha    "8cd7b299210a5f1cf96e67828c31a93fbbabde16"
                      :rust/crate "crates/cljrs-base64"
                      :rust/init  "cljrs-base64::cljrs_init"
                      :rust/load  :dylib}}
 :paths ["src"]}
